#include <iostream>
#include <vector>
#include <string>
using namespace std;
 
void solve() {
    int n;
    cin >> n;
    string s;
    cin >> s;
    //answer = n-1
    if (s == "1") {
        cout << 0 << "
";
        return; 
    }
    //answer = n
    int cnt = 0;
    for (int i = 0; i < n; ++i) {
        cnt += (s[i] == '1');
    }
    if (cnt == 0) {
        cout << -1 << "
";
        return;
    }
    if (cnt >= (n + 1) / 2) {
        cout << n << "
";
        return;
    }
    //answer = n+1
    if (2*cnt-n == -1) {
        cout << n + 1 << "
";
        return;
    }
    vector<int> p(n + 1);
    for (int i = 1; i <= n; ++i) {
        p[i] = p[i - 1] + (s[i-1] == '1') - (s[i-1] == '0');
    }
 
    for (int i = 1; i <= n; ++i) {
        if (p[i] > 0 || p[n] - p[i - 1] > 0) {
            cout << n + 1 << "
";
            return;
        }
    }
 
    //answer = n+2
    for (int i = 1; i <= n; ++i) {
        if (p[i] >= 0 || p[n] - p[i - 1] >= 0) {
            cout << n + 2 << "
";
            return;
        }
    }
    for (int i = 1; i <= n; ++i) {
        if(s[i] == '1' && s[i-1] == '1'){
            cout << n + 2 << "
";
            return;
        }
    }
 
    //answer = n+3
    cout << n + 3 << "
";
    return;
}
 
 
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    int t;
    cin >> t;
    while (t--) {
        solve();
    }
}